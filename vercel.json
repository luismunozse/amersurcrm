{
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "framework": "nextjs",
  "regions": ["gru1"],
  "crons": [
    {
      "path": "/api/notifications/send-recordatorios",
      "schedule": "*/5 * * * *"
    },
    {
      "path": "/api/cron/reportes-alertas",
      "schedule": "*/30 * * * *"
    },
    {
      "path": "/api/cron/cobranza-alertas",
      "schedule": "0 13 * * *"
    }
  ],
  "env": {
    "NODE_OPTIONS": "--max-old-space-size=3072"
  }
}
